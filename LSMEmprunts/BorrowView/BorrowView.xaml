<rxui:ReactiveUserControl x:Class="LSMEmprunts.BorrowView" x:TypeArguments="local:BorrowViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:rxui="http://reactiveui.net"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LSMEmprunts"
             xmlns:data="clr-namespace:LSMEmprunts.Data"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=local:BorrowViewModel}" 
             d:DesignHeight="600" d:DesignWidth="600">
<Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="UsersPart" Grid.Row="0" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0">Saisissez votre nom</TextBlock>
            <TextBox x:Name="UserNameInput" Grid.Row="1">
                <i:Interaction.Behaviors>
                    <local:CaptureKeyboardBehavior Active="{Binding UserSelected, Converter={StaticResource BoolToInvertConverter}}" />
                </i:Interaction.Behaviors>
            </TextBox>

            <ListBox x:Name="ListUsers" Grid.Row="2">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type data:User}">
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <TextBlock>Utilisateur : </TextBlock>
                <TextBlock x:Name="SelectedUserLbl" FontWeight="Bold" />
            </StackPanel>
        </Grid>
        
        

        <Rectangle Grid.Row="0" Grid.Column="1" Width="5" Fill="Black" />

        <Grid Grid.Row="0" Grid.Column="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0">Scannez la matériel ou double cliquez dans la liste</TextBlock>
            <TextBox x:Name="GearIdInputTxt" Grid.Row="1">
                <i:Interaction.Behaviors>
                    <local:CaptureKeyboardBehavior Active="{Binding GearTextBoxShallRetainFocus}" />
                </i:Interaction.Behaviors>
            </TextBox>
            
            <ListBox x:Name="ListGears" Grid.Row="2" Margin="0,5,0,5" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:GearBorrowInfo}">
                            <TextBlock Text="{Binding Name}" FontWeight="{Binding Available, Converter={StaticResource BoolToBoldConverter}}">
                                <UIElement.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick" 
                                                  Command="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=DataContext.SelectGearCommand}"
                                                  CommandParameter="{Binding }"/>
                                </UIElement.InputBindings>
                            </TextBlock>                            
                    </DataTemplate>
                </ListBox.ItemTemplate>
                
            </ListBox>

        </Grid>

        <Rectangle Grid.Row="0" Grid.Column="3" Width="5" Fill="Black" />

        <Grid Grid.Row="0" Grid.Column="4" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0">Commentaire</TextBlock>
            <TextBox x:Name="CommentTxt" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True">
                <i:Interaction.Behaviors>
                    <local:SetFocusBehavior IsFocused="{Binding CommentTextBoxFocused}" />
                </i:Interaction.Behaviors>
            </TextBox>

            <ListView x:Name="BorrowedGearGrid" Grid.Row="2" Margin="0 5" IsEnabled="False">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type, Converter={StaticResource GearTypeConverter}}" Width="70"/>
                        <GridViewColumn Header="Nom" DisplayMemberBinding="{Binding Name}" Width="200" />
                    </GridView>
                </ListView.View>
            </ListView>
            
        </Grid>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="4" HorizontalAlignment="Right">
            <Button x:Name="ValidateBtn" HorizontalAlignment="Center" Margin="5">
                <Grid Width="70" Height="70" Margin="5" Background="{StaticResource CheckIcon}">
                    <TextBlock x:Name="TickerLbl" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Button>
            <Button x:Name="CancelBtn" HorizontalAlignment="Center" Margin="5">
                <Rectangle Width="70" Height="70" Margin="5" Fill="{StaticResource CancelIcon}"/>
            </Button>
        </StackPanel>
    </Grid>
</rxui:ReactiveUserControl>
