<rxui:ReactiveUserControl x:Class="LSMEmprunts.HomeView" x:TypeArguments="local:HomeViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:rxui="http://reactiveui.net"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LSMEmprunts" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                          mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="800"
             d:DataContext="{d:DesignInstance Type=local:HomeViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <TextBlock HorizontalAlignment="Center" FontSize="48" Margin="10">LSM - Emprunt Matériel</TextBlock>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Rectangle Grid.Column="1" Width="5" Fill="Black" />

            <UniformGrid Grid.Column="0" Rows="2">
                <Button x:Name="BorrowBtn" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Vertical">
                        <Rectangle Margin="5" Height="70" Width="70" Fill="{DynamicResource BorrowIcon}" />
                        <TextBlock HorizontalAlignment="Center">Emprunt</TextBlock>
                    </StackPanel>
                </Button>
                <Button x:Name="ReturnBtn" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Vertical">
                        <Rectangle Margin="5" Height="70" Width="70" Fill="{DynamicResource ReturnIcon}" />
                        <TextBlock HorizontalAlignment="Center">Retour</TextBlock>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Grid Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock FontSize="36" HorizontalAlignment="Center" Margin="5">Emprunts en cours</TextBlock>

                <ListView x:Name="ActiveBorrowingsList" Grid.Row="1">
                    <i:Interaction.Behaviors>
                        <local:GridViewColumnSortBehavior/>
                    </i:Interaction.Behaviors>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Emprunteur" DisplayMemberBinding="{Binding User.Name}" Width="220"/>
                            <GridViewColumn Header="Téléphone" DisplayMemberBinding="{Binding User.Phone}" Width="160"/>
                            <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Gear.Type, Converter={StaticResource GearTypeConverter}}" Width="150"/>
                            <GridViewColumn Header="Matériel" DisplayMemberBinding="{Binding Gear, Converter={StaticResource GearDisplayNameConverter}}" Width="150"
                                            local:GridViewColumnSortBehavior.Sort="Gear.Name"/>
                            <GridViewColumn Header="Date" DisplayMemberBinding="{Binding BorrowTime, StringFormat=\{0:dd.MM.yy HH:mm\}}" Width="150"/>
                        </GridView>
                    </ListView.View>

                </ListView>
            </Grid>
        </Grid>

        <Button x:Name="SettingsBtn" Grid.Row="2" HorizontalAlignment="Left" Margin="5">
            <Rectangle Width="70" Height="70" Margin="5" Fill="{StaticResource SettingsIcon}"/>
        </Button>
    </Grid>
</rxui:ReactiveUserControl>
