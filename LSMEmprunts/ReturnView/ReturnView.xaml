<rxui:ReactiveUserControl x:Class="LSMEmprunts.ReturnView" x:TypeArguments="local:ReturnViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:rxui="http://reactiveui.net"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:LSMEmprunts"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=local:ReturnViewModel}"
             d:DesignHeight="600" d:DesignWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Rectangle Grid.Column="1" Width="5" Fill="Black" />

        <Grid Grid.Column="0" Grid.Row="0" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
                
            <TextBlock Grid.Row="0">Scannez le matériel ou double cliquez dessus</TextBlock>
            <TextBox x:Name="SelectedGearIdTextBox" Grid.Row="1">
                <i:Interaction.Behaviors>
                    <local:CaptureKeyboardBehavior />
                </i:Interaction.Behaviors>
            </TextBox>
            <ListBox x:Name="GearsList" Grid.Row="2" Margin="0,10,0,5" HorizontalContentAlignment="Stretch" >
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:GearReturnInfo}">
                        <TextBlock Text="{Binding Name}" FontWeight="{Binding Borrowed, Converter={StaticResource BoolToBoldConverter}}">
                            <UIElement.InputBindings>
                                <MouseBinding Gesture="LeftDoubleClick" 
                                              Command="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=DataContext.SelectGearCommand}"
                                              CommandParameter="{Binding }"/>
                            </UIElement.InputBindings>    
                            </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                    
            </ListBox>
        </Grid>

        <ListView x:Name="ClosingBorrowingsList" Grid.Column="2" Margin="10">
            <i:Interaction.Behaviors>
                <local:GridViewColumnSortBehavior/>
            </i:Interaction.Behaviors>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nom" DisplayMemberBinding="{Binding Borrowing.Gear.Name}" Width="200"/>
                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Borrowing.Gear.Type, Converter={StaticResource GearTypeConverter}}" Width="150"/>
                    <GridViewColumn Header="Remarque" DisplayMemberBinding="{Binding Comment}" Width="200"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Right">
            <Button x:Name="ValidateBtn" HorizontalAlignment="Center" Margin="5">
                <Grid Width="70" Height="70" Margin="5" Background="{StaticResource CheckIcon}">
                    <TextBlock x:Name="RemainingTimeTextBlock" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Grid>
            </Button>
            <Button x:Name="CancelBtn" HorizontalAlignment="Center" Margin="5">
                <Rectangle Width="70" Height="70" Margin="5" Fill="{StaticResource CancelIcon}"/>
            </Button>
        </StackPanel>
        
    </Grid>    
</rxui:ReactiveUserControl>
