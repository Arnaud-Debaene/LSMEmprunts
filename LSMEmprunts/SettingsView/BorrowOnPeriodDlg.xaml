<rxui:ReactiveUserControl x:Class="LSMEmprunts.BorrowOnPeriodDlg" x:TypeArguments="local:BorrowOnPeriodViewModel"
        xmlns:rxui="http://reactiveui.net"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSMEmprunts"
        xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=local:BorrowOnPeriodViewModel}"
        Height="600" Width="950" FontSize="18">
    <Border Style="{StaticResource DialogBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Rectangle Fill="Black" Width="5" Grid.Column="1" />

            <StackPanel Orientation="Vertical" Grid.Row="0" Grid.Column="0" Margin="10">
                <TextBlock Text="Date début" />
                <xceed:DateTimePicker x:Name="FromDatePicker" Width="250" Kind="Local" Format="Custom" FormatString="g"
                                  Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}"/>

                <TextBlock Text=" Date Fin" Margin="0 50 0 0" />
                <xceed:DateTimePicker x:Name="ToDatePicker" Width="250" Kind="Local" Format="Custom" FormatString="g"
                                  Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}"/>
                <CheckBox x:Name="IsInclusiveCheckBox" Margin="0 100 0 0" VerticalContentAlignment="Center">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Emprunts entièrement" />
                        <TextBlock Text="dans la période" />
                    </StackPanel>
                </CheckBox>
            </StackPanel>

            <ListView x:Name="BorrowsGrid" Grid.Row="0" Grid.Column="2">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Nom" DisplayMemberBinding="{Binding User}" Width="150"/>
                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding GearType, Converter={StaticResource GearTypeConverter}}" Width="100"/>
                        <GridViewColumn Header="Matériel" DisplayMemberBinding="{Binding Gear}" Width="90"/>
                        <GridViewColumn Header="Date début" DisplayMemberBinding="{Binding FromDate, StringFormat=\{0:dd.MM.yy HH:mm\}}" Width="150"/>
                        <GridViewColumn Header="Date Fin" DisplayMemberBinding="{Binding ToDate, StringFormat=\{0:dd.MM.yy HH:mm\}}" Width="150"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.ColumnSpan="3" HorizontalAlignment="Center">
                <Button x:Name="ExportCsvBtn" Margin="5">
                    <Rectangle Width="70" Height="70" Margin="5" Fill="{StaticResource CsvIcon}" />
                </Button>
                <Button x:Name="CloseBtn" HorizontalAlignment="Center" Margin="5" >
                    <Rectangle Width="70" Height="70" Margin="5" Fill="{StaticResource CancelIcon}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</rxui:ReactiveUserControl>
